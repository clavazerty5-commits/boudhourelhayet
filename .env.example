# === Local Development (SQLite) ===
DATABASE_URL=file:./dev.db

# === Production (Turso Cloud Database) ===
# Get these from https://turso.tech after creating a database
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOiJF...

# === Store Configuration ===
# These are set in the admin panel after deployment
# storeName, currency, contactEmail, etc.

# === Optional: Facebook Pixel ===
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your_pixel_id
